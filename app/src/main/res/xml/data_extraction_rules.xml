<?xml version="1.0" encoding="utf-8"?>
<!--
   Controls Auto Backup (cloud) and device-to-device transfer on API 31+.
   The launcher's preferences hold privacy-sensitive data (the biometric-gated
   hidden-apps list) and behavioral data (per-app usage stats), so these stores are
   excluded from any off-device copy. backup_rules.xml mirrors this for the legacy path.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="swyplauncher_prefs.xml" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="swyplauncher_prefs.xml" />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
